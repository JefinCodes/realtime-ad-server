generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CampaignStatus {
  active
  paused
  ended
}

model Advertiser {
  id              String   @id @default(uuid()) @db.Uuid
  authUserId      String   @unique @map("auth_user_id") @db.Uuid
  name            String   @db.VarChar(100)
  email           String   @unique @db.VarChar(255)
  walletBalance   Decimal  @default(0) @map("wallet_balance") @db.Decimal(12,2)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt
  campaigns       Campaign[]

  @@index([authUserId])
  @@map("advertisers")
}

model Campaign {
  id                String          @id @default(uuid()) @db.Uuid
  advertiserId      String          @map("advertiser_id") @db.Uuid
  advertiser        Advertiser      @relation(fields: [advertiserId], references: [id], onDelete: Cascade)
  name              String          @db.VarChar(200)
  bid               Decimal         @db.Decimal(10,4)
  budget            Decimal         @db.Decimal(12,2)
  remainingBudget   Decimal         @map("remaining_budget") @db.Decimal(12,2)
  status            CampaignStatus  @default(active)
  headline          String          @db.VarChar(255)
  description       String
  imageUrl          String          @map("image_url")
  startDate         DateTime        @map("start_date") @db.Timestamptz
  endDate           DateTime        @map("end_date") @db.Timestamptz
  createdAt         DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime        @updatedAt

  impressions       Impression[]

  @@index([advertiserId])
  @@index([status])
  @@map("campaigns")
}

model Impression {
  id           String      @id @default(uuid()) @db.Uuid
  campaignId   String      @map("campaign_id") @db.Uuid
  campaign     Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  deviceType   String?     @map("device_type") @db.VarChar(50)
  timestamp    DateTime    @default(now()) @db.Timestamptz
  click        Click?
  
  @@index([campaignId, timestamp])
  @@index([timestamp])
  @@map("impressions")
}

model Click {
  id             String       @id @default(uuid()) @db.Uuid
  impressionId   String       @unique @map("impression_id") @db.Uuid
  impression     Impression   @relation(fields: [impressionId], references: [id], onDelete: Cascade)
  timestamp      DateTime     @default(now()) @db.Timestamptz

  @@index([timestamp])
  @@map("clicks")
}
